{
  "name": "scripturai",
  "version": "1.0.0",
  "description": "Scripturai — The Living Word. AI-powered Bible reading and study app.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite --force",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "format": "prettier --write src",
    "backend": "cd backend && npm run dev",
    "backend:start": "cd backend && npm start",
    "install:all": "npm install && cd backend && npm install",
    "convert-bibles": "node src/js/convert-bibles.js"
  },
  "keywords": [
    "bible",
    "scripture",
    "ai",
    "study",
    "devotional"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "sharp": "^0.34.5",
    "terser": "^5.16.0",
    "vite": "^5.0.0",
    "xml2js": "^0.6.2"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "firebase": "^12.12.1",
    "fuse.js": "^7.4.1",
    "openai": "^4.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "serverless-http": "^3.2.0"
  }
}
